@ARTICLE{Starr2004assessing-0001,
  title     = "Assessing interaction in case-control studies: type {I} errors
               when using both additive and multiplicative scales: Type {I}
               errors when using both additive and multiplicative scales",
  author    = "Starr, Jacqueline R and McKnight, Barbara",
  journal   = "Epidemiology",
  publisher = "Ovid Technologies (Wolters Kluwer Health)",
  volume    =  15,
  number    =  4,
  pages     = "422--427",
  abstract  = "Epidemiologic researchers often explore effect modification in
               case-control studies on more than one statistical scale, an
               approach that one expects would increase the rate of
               false-positive findings of interaction. For example, researchers
               have measured effect modification by using both a multiplicative
               interaction coefficient (M) in a logistic regression model and a
               measure of interaction on the additive scale such as the
               interaction coefficient from an additive relative risk regression
               model (A). We performed computer simulations to investigate the
               degree to which type I error may be inflated when statistical
               interactions are evaluated by using both M and A. The overall
               type I error rate was often greater than 5\% when both tests were
               performed together. These results provide empiric evidence of the
               limited validity of a common approach to assessing etiologic
               effect modification. When the scale has not been specified before
               analysis, interaction hypothesis tests of effect modification
               should be interpreted particularly cautiously. Researchers are
               not justified in choosing the interaction test with the lowest P
               value.",
  month     =  jul,
  year      =  2004,
  url       = "http://dx.doi.org/10.1097/01.ede.0000129508.82783.94",
  keywords  = "ICEMAN/references manual;ICEMAN/references
               manual;ICEMAN/references manual",
  doi       = "10.1097/01.ede.0000129508.82783.94",
  pmid      =  15232402,
  issn      = "1044-3983,1531-5487",
  annote    = "ICEMAN\_REF\_65: Starr JR, McKnight B. Assessing interaction in
               case-control studies: type I errors when using both additive and
               multiplicative scales. Epidemiology. 2004;15(4):422-7.",
  language  = "en"
}

