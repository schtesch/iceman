@ARTICLE{Veroniki2019methods,
  title     = "Methods to calculate uncertainty in the estimated overall effect
               size from a random-effects meta-analysis",
  author    = "Veroniki, Areti Angeliki and Jackson, Dan and Bender, Ralf and
